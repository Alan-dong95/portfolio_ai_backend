# Zeabur / 生产环境变量 — 复制到 Zeabur Variables，勿提交真实密钥。

APP_NAME=portfolio-ai-api
ENVIRONMENT=production

# 运行时：Supabase Session pooler（端口 5432）
# 可直接粘贴 Supabase 面板的 URI，代码会自动转为 postgresql+psycopg:// 并加 sslmode=require
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# 迁移：Supabase Direct connection（Alembic 推荐，避免 pooler 限制）
ALEMBIC_DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

DATABASE_ECHO=false

NEWS_API_KEY=
NEWS_CACHE_TTL_SECONDS=900

LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_ENABLED=true
LLM_CACHE_TTL_SECONDS=3600
BRIEF_CACHE_TTL_SECONDS=1800

# MVP 单 worker 用 memory；多 worker 请接 Upstash 并设 CACHE_BACKEND=redis
CACHE_BACKEND=memory
REDIS_URL=

RUN_MIGRATIONS=true
UVICORN_WORKERS=1

# Zeabur 会自动注入 PORT；本地 Docker 默认 8000
# PORT=8080

# 移动端 MVP 可保持 *；以后 Web 上线再改具体域名
CORS_ORIGINS=*
