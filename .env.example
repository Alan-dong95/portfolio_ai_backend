APP_NAME=portfolio-ai-api
ENVIRONMENT=development

# PostgreSQL (required)
DATABASE_URL=postgresql+psycopg://portfolio:portfolio@localhost:5432/portfolio_ai
DATABASE_ECHO=false

# NewsAPI
NEWS_API_KEY=
NEWS_CACHE_TTL_SECONDS=900

# LLM — OpenAI or DeepSeek
LLM_PROVIDER=openai
LLM_MODEL=deepseek-v4-flash
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_ENABLED=true
LLM_CACHE_TTL_SECONDS=3600
BRIEF_CACHE_TTL_SECONDS=1800

# Cache — memory (dev) or redis (production)
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
